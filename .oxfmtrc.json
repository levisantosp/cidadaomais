{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["dist", "postgres", ".github", "node_modules"],
  "singleQuote": true,
  "semi": false,
  "trailingComma": "none",
  "printWidth": 80,
  "vueIndentScriptAndStyle": true,
  "sortImports": {
    "order": "asc",
    "newlinesBetween": false
  }
}
