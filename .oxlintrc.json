{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "warn"
  },
  "rules": {
    "eslint/no-await-in-loop": "off",
    "eslint/no-unused-vars": "warn"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist", "postgres", ".github", "node_modules"]
}